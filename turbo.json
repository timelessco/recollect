{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:next": {
      "env": [
        "NODE_ENV",
        "VERCEL_ENV",
        "SUPABASE_SERVICE_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "DEV_SUPABASE_SERVICE_KEY",
        "UMAMI_SRC",
        "SENTRY_PROJECT",
        "SENTRY_ORG",
        "SENTRY_AUTH_TOKEN",
        "API_KEY_ENCRYPTION_KEY",
        "UMAMI_ID",
        "PDF_SECRET_KEY",
        "PDF_URL_SCREENSHOT_API",
        "GOOGLE_GEMINI_TOKEN",
        "RESEND_KEY",
        "REVALIDATE_SECRET_TOKEN"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "test": {},
    "lint:types": {
      "inputs": ["**/*.{ts,tsx,d.ts,cts,d.cts,mts,d.mts}"],
      "outputs": ["*.tsbuildinfo"]
    },
    "lint:eslint": {
      "outputs": [".eslintcache"]
    },
    "lint:oxfmt": {},
    "lint:css": {
      "inputs": ["**/*.css"],
      "outputs": [".stylelintcache"]
    },
    "lint:md": {
      "inputs": ["**/*.md", ".github/**/*.md"]
    },
    "lint:spelling": {
      "outputs": [".cspellcache"]
    },
    "fix:md": {
      "inputs": ["**/*.md", ".github/**/*.md"]
    },
    "fix:css": {
      "inputs": ["**/*.css"],
      "outputs": [".stylelintcache"]
    },
    "fix:spelling": {
      "outputs": [".cspellcache"]
    },
    "fix:oxfmt": {
      "dependsOn": ["fix:md", "fix:css", "fix:spelling"]
    },
    "fix:eslint": {
      "dependsOn": ["fix:oxfmt"],
      "outputs": [".eslintcache"]
    }
  }
}
