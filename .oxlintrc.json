{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/next/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/vitest/.oxlintrc.json",
    "./.configs/oxlint/perfectionist.json",
    "./.configs/oxlint/regexp.json",
    "./.configs/oxlint/tanstack-query.json",
    "./.configs/oxlint/eslint-react.json"
  ],
  "options": {
    "reportUnusedDisableDirectives": "error",
    "typeAware": false,
    "typeCheck": false
  },
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "public/**",
    ".next/**",
    "next-env.d.ts",
    "CHANGELOG.md",
    "scripts/release-it/**",
    ".agents/**",
    ".claude/**",
    "scripts/utils/try.ts",
    ".ncurc.cjs",
    "supabase/functions/**",
    "package-typings/**"
  ],
  "rules": {
    "func-style": ["error", "declaration", { "allowArrowFunctions": true }],

    // void operator is used idiomatically to discard Promise return values (void someAsync())
    // without triggering no-floating-promises
    "no-void": "off",
    // perfectionist/sort-objects handles this with natural (case-insensitive) ordering
    "sort-keys": "off",
    // promise-function-async conflicts with require-await: it auto-adds async
    // to functions returning Promises, but require-await then complains about
    // no await. We prefer: only add async when await is present.
    "@typescript-eslint/promise-function-async": "off",

    // Disabled: jsPlugin auto-fix oscillates on multi-line objects/unions/query hooks
    "@tanstack/query/mutation-property-order": "off",
    "@tanstack/query/infinite-query-property-order": "off",
    "perfectionist/sort-objects": "off",
    "perfectionist/sort-union-types": "off",

    // Disabled: common codebase patterns, not worth enforcing
    "react-x/set-state-in-effect": "off",
    "react-x/no-array-index-key": "off",

    // Disabled during migration — enable incrementally
    "@typescript-eslint/no-confusing-void-expression": "off",
    "@typescript-eslint/no-empty-interface": "off",
    "@typescript-eslint/no-floating-promises": "off",
    "@typescript-eslint/no-namespace": "off",
    "@typescript-eslint/no-non-null-asserted-optional-chain": "off",
    "@typescript-eslint/no-redundant-type-constituents": "off",
    "@typescript-eslint/no-unnecessary-template-expression": "off",
    "class-methods-use-this": "off",
    "complexity": "off",
    "default-case": "off",
    "default-param-last": "off",
    "max-classes-per-file": "off",
    "max-lines": "off",
    "max-statements": "off",
    "no-else-return": "off",
    "no-accumulating-spread": "off",
    "const-comparisons": "off",
    "no-constant-binary-expression": "off",
    "no-unused-vars": "off",
    "no-empty-function": "off",
    "no-negated-condition": "off",
    "no-nested-ternary": "off",
    "no-plusplus": "off",
    "no-shadow": "off",
    "no-use-before-define": "off",
    "no-useless-return": "off",
    "no-warning-comments": "off",
    "prefer-destructuring": "off",
    "prefer-template": "off",
    "require-await": "off",
    "import/namespace": "off",
    "import/no-cycle": "off",
    "import/no-named-as-default": "off",
    "jsdoc/require-param-description": "off",
    "jsdoc/require-returns-description": "off",
    "promise/avoid-new": "off",
    "promise/no-nesting": "off",
    "promise/prefer-await-to-callbacks": "off",
    "promise/prefer-await-to-then": "off",
    "jsx-a11y/prefer-tag-over-role": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react/jsx-no-useless-fragment": "off",
    "react/no-danger": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-anonymous-default-export": "off",
    "unicorn/no-array-for-each": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/no-document-cookie": "off",
    "unicorn/no-immediate-mutation": "off",
    "unicorn/no-static-only-class": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/no-await-expression-member": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/prefer-dom-node-dataset": "off",
    "unicorn/prefer-spread": "off",
    "unicorn/prefer-ternary": "off",
    "@typescript-eslint/ban-ts-comment": "off",
    "@typescript-eslint/ban-types": "off",
    "@typescript-eslint/no-deprecated": "off",
    "@typescript-eslint/no-empty-object-type": "off",
    "@typescript-eslint/no-inferrable-types": "off",
    "@typescript-eslint/no-misused-promises": "off",
    "@typescript-eslint/no-non-null-assertion": "off",
    "@typescript-eslint/no-unsafe-argument": "off",
    "@typescript-eslint/no-unsafe-assignment": "off",
    "@typescript-eslint/no-unsafe-call": "off",
    "@typescript-eslint/no-unsafe-member-access": "off",
    "@typescript-eslint/no-unsafe-return": "off",
    "@typescript-eslint/no-unsafe-type-assertion": "off",
    "@typescript-eslint/restrict-template-expressions": "off",
    "@typescript-eslint/strict-boolean-expressions": "off",
    "@typescript-eslint/unbound-method": "off"
  },
  "overrides": [
    {
      "files": ["**/*.{js,cjs,jsx,ts,tsx}"],
      "rules": {
        // TODO: Should fix these issues in multiple files
        "react-x/set-state-in-effect": "off",
        "react-x/no-array-index-key": "off"
      }
    },
    {
      "files": ["**/*.{test,spec}.{ts,tsx,js,jsx}", "**/__tests__/**/*.{ts,tsx,js,jsx}"],
      "plugins": ["vitest"],
      "rules": {
        "vitest/prefer-describe-function-title": "off"
      }
    }
  ]
}
