## PNPM related ###############
## https://pnpm.io/npmrc      #
###############################

# Save exact versions instead of ranges (default: false, which adds '^' prefix)
# https://pnpm.io/npmrc#save-exact
save-exact=true

# Automatically install peer dependencies
# https://pnpm.io/npmrc#auto-install-peers
auto-install-peers=true

## Security Configuration #####

# Wait 3 days before using newly published packages (value in minutes)
# Gives the security community time to detect and remove malicious releases
# https://pnpm.io/settings#minimumreleaseage
minimumReleaseAge=4320
